#include <iostream>
using namespace std;

int main() {
    int n, menor, maior;
    
    cout << "Digite 10 numeros para ver o intervalo entre o menor e o maior." << endl;
    
    int num;
    for(int i = 0; i < 10; i++) {
        cout << "Numero " << i+1 << ": ";
        cin >> num;
        
        if(i == 0) {
            menor = num;
            maior = num;
        } else {
            if(num < menor) menor = num;
            if(num > maior) maior = num;
        }
    }

    cout << "O menor digitado foi: " << menor << endl;
    cout << "O maior digitado foi: " << maior << endl;

    return 0;
}