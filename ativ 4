#include <iostream>
using namespace std;

int main() {
    int a, b, c;
    cout << "Digite tres numeros: ";
    cin >> a >> b >> c;
    if (a >= b && a >= c) {
        cout << "O maior e: " << a << endl;
    } else if (b >= a && b >= c) {
        cout << "O maior e: " << b << endl;
    } else {
        cout << "O maior e: " << c << endl;
    }
    return 0;
}